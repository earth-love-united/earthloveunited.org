# ═══════════════════════════════════════════════════════════════
# Earth Love United — .gitignore
# ═══════════════════════════════════════════════════════════════
# Large datasets live on Hugging Face. Local copies are gitignored.
# See tools/fetch-data.sh for download instructions.

# ─── OS ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Editor / IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Dependencies (we are BARE METAL — should never appear) ────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ─── Environment & secrets ─────────────────────────────────────
.env
.env.*
*.pem
*.key
secrets/
.wrangler/

# ─── Python ─────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
.python-version

# ─── Agent tooling artifacts (local context, not for repo) ─────
agents-insights/
.hermes-skills.yaml
.cursor/
.continue/

# ─── Build / dist artifacts ─────────────────────────────────────
dis/dist/
build/

# ─── Generated third-party scripts (fetch + verify with repository tools) ─
js/vendor/

# ─── Large data files (live on Hugging Face Datasets) ──────────
# Climate knowledge corpus
dis/climate-facts.json

# Carbon projects — all heavy data lives on Hugging Face (see tools/fetch-data.sh)
# (carbon-projects/ moved to ~/Desktop/datasets/)

# Scraper outputs (re-scrape or fetch from HF)
tools/scraper/data/external/
tools/scraper/data/scraped/

# Machine-specific scraper binaries (symlinked from local paths)
tools/scraper/bin/

# Large binary assets
textures/ndvi/

# ─── Backup files ───────────────────────────────────────────────
*.bak
*.bak.*
*.bak*/
*.orig

# ─── Local-only design / scratch files ─────────────────────────
design/modules/serve.py
_dead/

# Generated / deployment artefacts (not for git)
_deploy/
_deploy_beta/
# NOTE: manifest.json (PWA manifest at repo root) is a SOURCE file — do not ignore.

# ─── Infra safety backups (local only) ─────────────────────────
.infra-backup/

# ─── Data purged from history (live on Hugging Face) ───────────
# Added 2026-06-06 after history rewrite — never re-track these.
tools/scraper/data/
data/*.jsonl

# ─── Moved to ~/Desktop/datasets/ ──────────────────────────────
climate-dataset/
carbon-projects/
holocene-bifurcation/

# ─── Archive (stale docs / design prototypes) ───────────────────
_archive/

# ─── Runtime site assets: intentionally force-TRACKED for deploy ─
# The specific files the live site loads (dist/knowledge/*,
# textures/ndvi/*) are committed via `git add -f` so Cloudflare's
# clean build is self-contained. The broad ignores above still apply
# to NEW files.

# Archived legacy-site reference material (source for foundation copy)
legacy-site/

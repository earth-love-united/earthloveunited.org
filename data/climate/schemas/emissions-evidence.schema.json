{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/emissions-evidence.schema.json",
  "title": "Country emissions evidence artifact",
  "type": "object",
  "required": ["schema_version", "schema_ref", "release_id", "release_status", "evidence_plane", "metric", "series"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "schema_ref": {"const": "../../schemas/emissions-evidence.schema.json"},
    "release_id": {"type": "string", "minLength": 1},
    "release_status": {"enum": ["blocked_source_unavailable", "staged_identity_review", "fixture_only"]},
    "compiled_on": {"type": ["string", "null"], "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "evidence_plane": {"const": "harmonized"},
    "metric": {"const": "territorial_fossil_co2"},
    "accounting": {"type": "object"},
    "source": {"type": "object"},
    "identity_policy": {"type": "object"},
    "availability": {"type": "object"},
    "series": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_entity_id", "source_entity_name", "canonical_country_id", "identity_link_status", "observations"],
        "properties": {
          "source_entity_id": {"type": "string", "pattern": "^gcb:[a-z0-9-]+$"},
          "source_entity_name": {"type": "string", "minLength": 1},
          "canonical_country_id": {"type": "null"},
          "identity_link_status": {"const": "not_reviewed"},
          "observations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["year", "value", "unit", "status", "uncertainty"],
              "properties": {
                "year": {"type": "integer", "minimum": 1800, "maximum": 2100},
                "value": {"type": ["number", "null"]},
                "unit": {"const": "MtCO2/yr"},
                "status": {"enum": ["estimated", "not_reported"]},
                "uncertainty": {
                  "type": "object",
                  "required": ["status", "lower", "upper"],
                  "properties": {
                    "status": {"const": "not_provided_at_country_year_level"},
                    "lower": {"type": "null"},
                    "upper": {"type": "null"}
                  },
                  "additionalProperties": false
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"release_status": {"const": "blocked_source_unavailable"}}},
      "then": {"properties": {"series": {"maxItems": 0}}, "required": ["availability"]}
    }
  ],
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/climate-finance-1.0.0.json",
  "title": "Typed climate finance fact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_kind", "finance_id", "country_id", "country_role", "counterparty", "flow_stage", "origin", "channel", "purpose", "instrument", "amount", "currency", "price_basis", "period", "evidence_plane", "uncertainty", "source", "review"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_kind": { "const": "climate_finance_fact" },
    "finance_id": { "type": "string", "pattern": "^finance:[a-z0-9][a-z0-9._:-]+$" },
    "country_id": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" },
    "country_role": { "enum": ["provider", "recipient"] },
    "counterparty": { "type": ["string", "null"] },
    "flow_stage": { "enum": ["provided", "mobilized", "committed", "disbursed", "needed", "received"] },
    "origin": { "enum": ["domestic", "international"] },
    "channel": { "enum": ["bilateral", "multilateral", "fund", "domestic"] },
    "purpose": { "enum": ["mitigation", "adaptation", "cross_cutting"] },
    "instrument": { "enum": ["grant", "loan", "guarantee", "equity", "other"] },
    "amount": { "type": "number", "minimum": 0 },
    "currency": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "price_basis": { "type": "object", "additionalProperties": false, "required": ["type", "base_year", "conversion_method"], "properties": { "type": { "enum": ["current", "constant"] }, "base_year": { "type": ["integer", "null"], "minimum": 1900 }, "conversion_method": { "type": ["string", "null"] } } },
    "period": { "type": "object", "additionalProperties": false, "required": ["start_date", "end_date"], "properties": { "start_date": { "type": "string", "format": "date" }, "end_date": { "type": "string", "format": "date" } } },
    "evidence_plane": { "enum": ["official", "harmonized", "independent"] },
    "uncertainty": { "type": ["object", "null"], "additionalProperties": false, "required": ["lower", "upper", "confidence", "method"], "properties": { "lower": { "type": "number", "minimum": 0 }, "upper": { "type": "number", "minimum": 0 }, "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }, "method": { "type": "string", "minLength": 1 } } },
    "source": { "type": "object", "additionalProperties": false, "required": ["source_registry_id", "document_title", "document_url", "locator", "version", "retrieved_at"], "properties": { "source_registry_id": { "type": "string", "minLength": 1 }, "document_title": { "type": "string", "minLength": 1 }, "document_url": { "type": "string", "pattern": "^https://" }, "locator": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "retrieved_at": { "type": "string", "format": "date" } } },
    "review": { "type": "object", "additionalProperties": false, "required": ["status", "extractor_id", "reviewer_id", "reviewed_at"], "properties": { "status": { "enum": ["not_reviewed", "in_review", "reviewed", "rejected", "superseded"] }, "extractor_id": { "type": "string", "minLength": 1 }, "reviewer_id": { "type": ["string", "null"] }, "reviewed_at": { "type": ["string", "null"], "format": "date-time" } } }
  }
}

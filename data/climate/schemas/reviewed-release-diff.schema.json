{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/reviewed-release-diff-1.0.0.json",
  "title": "Canonical independently reviewed climate release diff",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "initial_release", "data_release_id", "previous_release_id", "change_summary", "changed_entity_ids", "source_revision_ids", "artifact_pins", "review", "diff_hash"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "initial_release": { "type": "boolean" },
    "data_release_id": { "type": "string", "minLength": 1 },
    "previous_release_id": { "type": ["string", "null"] },
    "change_summary": { "type": "string", "minLength": 20 },
    "changed_entity_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "source_revision_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "artifact_pins": { "type": "array", "minItems": 3, "maxItems": 3, "uniqueItems": true, "items": { "$ref": "#/$defs/pin" } },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "builder_id", "reviewer_id", "reviewed_at"],
      "properties": {
        "status": { "const": "reviewed" },
        "builder_id": { "type": "string", "minLength": 5 },
        "reviewer_id": { "type": "string", "minLength": 5 },
        "reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "diff_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^data/climate/" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/ct40-reviewed-release-input-1.0.0.json",
  "title": "Reviewed input to the canonical CT-40 release evaluator",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "candidate", "source_rights_decisions", "review_context"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_release_id", "methodology_version", "evaluated_at", "sources", "facts", "fact_reviews", "conflicts", "profiles", "review"],
      "properties": {
        "data_release_id": { "type": "string", "minLength": 1 },
        "methodology_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "evaluated_at": { "type": "string", "format": "date-time" },
        "sources": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "facts": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "fact_reviews": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "conflicts": { "type": "array", "items": { "type": "object" } },
        "profiles": { "type": "array", "minItems": 1, "items": { "type": "object" } },
        "review": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "builder_id", "reviewer_ids", "reviewed_at"],
          "properties": {
            "status": { "const": "reviewed" },
            "builder_id": { "type": "string", "minLength": 5 },
            "reviewer_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 5 } },
            "reviewed_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    "source_rights_decisions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision_id", "source_id", "source_version", "source_checksum_sha256", "evidence_document_pins", "status", "redistribution_approved", "scoring_approved", "decision_by", "reviewer_id", "reviewed_at", "decision_hash"],
        "properties": {
          "decision_id": { "type": "string", "minLength": 5 },
          "source_id": { "type": "string", "minLength": 1 },
          "source_version": { "type": "string", "minLength": 1 },
          "source_checksum_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "evidence_document_pins": {
            "type": "array", "uniqueItems": true,
            "items": {
              "type": "object", "additionalProperties": false,
              "required": ["document_id", "path", "sha256"],
              "properties": {
                "document_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
                "path": { "type": "string", "pattern": "^data/climate/evidence/" },
                "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
              }
            }
          },
          "status": { "const": "reviewed" },
          "redistribution_approved": { "const": true },
          "scoring_approved": { "const": true },
          "decision_by": { "type": "string", "minLength": 5 },
          "reviewer_id": { "type": "string", "minLength": 5 },
          "reviewed_at": { "type": "string", "format": "date-time" },
          "decision_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        }
      }
    },
    "review_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "required_country_ids", "independently_reviewed_country_ids", "top20_primary_source_reviews", "reviewer_ids", "reviewed_at", "licence_decisions_complete", "field_level_fact_reviews_complete"],
      "properties": {
        "status": { "const": "reviewed" },
        "required_country_ids": { "type": "array", "minItems": 20, "maxItems": 20, "uniqueItems": true, "items": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" } },
        "independently_reviewed_country_ids": { "type": "array", "minItems": 20, "maxItems": 20, "uniqueItems": true, "items": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" } },
        "top20_primary_source_reviews": {
          "type": "array", "minItems": 20, "maxItems": 20, "uniqueItems": true,
          "items": {
            "type": "object", "additionalProperties": false,
            "required": ["country_id", "status", "official_inventory_document_ids", "active_ndc_document_ids", "target_methodology_document_ids", "extractor_id", "reviewer_id", "reviewed_at", "review_hash"],
            "properties": {
              "country_id": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" },
              "status": { "const": "reviewed" },
              "official_inventory_document_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" } },
              "active_ndc_document_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" } },
              "target_methodology_document_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" } },
              "extractor_id": { "type": "string", "minLength": 5 },
              "reviewer_id": { "type": "string", "minLength": 5 },
              "reviewed_at": { "type": "string", "format": "date-time" },
              "review_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
            }
          }
        },
        "reviewer_ids": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 5 } },
        "reviewed_at": { "type": "string", "format": "date-time" },
        "licence_decisions_complete": { "const": true },
        "field_level_fact_reviews_complete": { "const": true }
      }
    }
  }
}

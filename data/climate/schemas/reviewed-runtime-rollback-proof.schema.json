{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/reviewed-runtime-rollback-proof-1.0.0.json",
  "title": "Executable independently reviewed production runtime rollback proof",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "proof_id", "data_release_id", "status", "release_authority", "deploy_authority", "release_package_pins", "rollback", "review", "calculation_hash"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "proof_id": { "type": "string", "minLength": 5 },
    "data_release_id": { "type": "string", "minLength": 1 },
    "status": { "const": "reviewed" },
    "release_authority": { "const": false },
    "deploy_authority": { "const": false },
    "release_package_pins": { "type": "array", "minItems": 4, "maxItems": 4, "uniqueItems": true, "items": { "$ref": "#/$defs/pin" } },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "baseline_commit_sha", "patch", "controls"],
      "properties": {
        "strategy": { "const": "restore_pinned_baseline" },
        "baseline_commit_sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "patch": {
          "type": "object",
          "additionalProperties": false,
          "required": ["path", "encoding", "sha256", "decoded_sha256", "changed_files"],
          "properties": {
            "path": { "type": "string", "pattern": "^data/climate/operations/.+\\.patch\\.b64$" },
            "encoding": { "const": "base64" },
            "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "decoded_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
            "changed_files": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } }
          }
        },
        "controls": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/control" } }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "builder_id", "reviewer_id", "reviewed_at"],
      "properties": {
        "status": { "const": "reviewed" },
        "builder_id": { "type": "string", "minLength": 5 },
        "reviewer_id": { "type": "string", "minLength": 5 },
        "reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "calculation_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "pin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^data/climate/" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "control": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "release_sha256", "rollback_sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "release_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rollback_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/policy-measure-1.0.0.json",
  "title": "Implemented climate policy or measure evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_kind", "policy_id", "country_id", "evidence_plane", "jurisdiction", "title", "legal_status", "adoption_date", "effective_date", "sectors", "instruments", "implementation", "effects", "source", "review"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_kind": { "const": "policy_measure" },
    "policy_id": { "type": "string", "pattern": "^policy:[a-z0-9][a-z0-9._:-]+$" },
    "country_id": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" },
    "evidence_plane": { "enum": ["official", "harmonized", "independent"] },
    "jurisdiction": {
      "type": "object", "additionalProperties": false,
      "required": ["level", "name", "geography"],
      "properties": {
        "level": { "enum": ["national", "subnational", "supranational"] },
        "name": { "type": "string", "minLength": 1 },
        "geography": { "type": "string", "minLength": 1 }
      }
    },
    "title": { "type": "string", "minLength": 1 },
    "legal_status": { "enum": ["proposed", "adopted", "in_force", "partially_in_force", "suspended", "repealed", "expired", "not_assessed"] },
    "adoption_date": { "type": ["string", "null"], "format": "date" },
    "effective_date": { "type": ["string", "null"], "format": "date" },
    "sectors": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 1 } },
    "instruments": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "enum": ["law", "regulation", "standard", "tax", "emissions_trading", "subsidy", "public_investment", "information", "voluntary_agreement", "planning", "other"] } },
    "implementation": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "evidence_fact_ids", "notes"],
      "properties": {
        "status": { "enum": ["not_started", "partial", "implemented", "completed", "not_assessed"] },
        "evidence_fact_ids": { "type": "array", "uniqueItems": true, "items": { "type": "string", "pattern": "^fact:" } },
        "notes": { "type": ["string", "null"] }
      }
    },
    "effects": {
      "type": "object", "additionalProperties": false,
      "required": ["expected", "observed"],
      "properties": {
        "expected": { "type": "array", "items": { "$ref": "#/$defs/effect" } },
        "observed": { "type": "array", "items": { "$ref": "#/$defs/effect" } }
      }
    },
    "source": { "$ref": "#/$defs/source" },
    "review": { "$ref": "#/$defs/review" }
  },
  "$defs": {
    "effect": {
      "type": "object", "additionalProperties": false,
      "required": ["effect_id", "metric", "value", "unit", "period", "method", "source_fact_id", "uncertainty"],
      "properties": {
        "effect_id": { "type": "string", "pattern": "^effect:" },
        "metric": { "type": "string", "minLength": 1 },
        "value": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 },
        "period": { "$ref": "#/$defs/period" },
        "method": { "enum": ["modeled", "projected", "measured", "evaluated", "official_reported"] },
        "source_fact_id": { "type": "string", "pattern": "^fact:" },
        "uncertainty": { "$ref": "#/$defs/uncertainty" }
      }
    },
    "period": {
      "type": "object", "additionalProperties": false, "required": ["start_year", "end_year"],
      "properties": { "start_year": { "type": "integer", "minimum": 1900 }, "end_year": { "type": "integer", "minimum": 1900 } }
    },
    "uncertainty": {
      "type": ["object", "null"], "additionalProperties": false, "required": ["lower", "upper", "confidence", "method"],
      "properties": { "lower": { "type": "number" }, "upper": { "type": "number" }, "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }, "method": { "type": "string", "minLength": 1 } }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["source_registry_id", "document_title", "document_url", "locator", "version", "retrieved_at"],
      "properties": {
        "source_registry_id": { "type": "string", "minLength": 1 }, "document_title": { "type": "string", "minLength": 1 },
        "document_url": { "type": "string", "pattern": "^https://" }, "locator": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }, "retrieved_at": { "type": "string", "format": "date" }
      }
    },
    "review": {
      "type": "object", "additionalProperties": false, "required": ["status", "extractor_id", "reviewer_id", "reviewed_at"],
      "properties": { "status": { "enum": ["not_reviewed", "in_review", "reviewed", "rejected", "superseded"] }, "extractor_id": { "type": "string", "minLength": 1 }, "reviewer_id": { "type": ["string", "null"] }, "reviewed_at": { "type": ["string", "null"], "format": "date-time" } }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/policy-projection-1.0.0.json",
  "title": "Official or harmonized policy scenario projection",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "record_kind", "data_role", "projection_id", "country_id", "evidence_plane", "scenario", "scope", "model", "unit", "points", "source", "review"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "record_kind": { "const": "policy_projection" },
    "data_role": { "const": "scenario_projection_only" },
    "projection_id": { "type": "string", "pattern": "^projection:[a-z0-9][a-z0-9._:-]+$" },
    "country_id": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" },
    "evidence_plane": { "enum": ["official", "harmonized", "independent"] },
    "scenario": {
      "type": "object", "additionalProperties": false, "required": ["name", "vintage", "policy_assumption", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }, "vintage": { "type": "string", "minLength": 1 },
        "policy_assumption": { "enum": ["with_measures", "with_additional_measures", "without_measures", "other"] },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "scope": {
      "type": "object", "additionalProperties": false, "required": ["accounting_frame", "gases", "gwp_convention", "sectors", "lulucf", "geography"],
      "properties": {
        "accounting_frame": { "enum": ["fossil_co2", "economy_wide_ghg", "lulucf", "sectoral"] },
        "gases": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "gwp_convention": { "type": ["string", "null"] },
        "sectors": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string" } },
        "lulucf": { "enum": ["included", "excluded", "separate", "not_applicable", "not_reported"] },
        "geography": { "type": "string", "minLength": 1 }
      }
    },
    "model": { "type": "object", "additionalProperties": false, "required": ["name", "version", "operator", "method"], "properties": { "name": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "operator": { "type": "string", "minLength": 1 }, "method": { "type": "string", "minLength": 1 } } },
    "unit": { "type": "string", "minLength": 1 },
    "points": {
      "type": "array", "minItems": 1,
      "items": { "type": "object", "additionalProperties": false, "required": ["year", "value", "uncertainty"], "properties": { "year": { "type": "integer", "minimum": 1900 }, "value": { "type": "number" }, "uncertainty": { "$ref": "#/$defs/uncertainty" } } }
    },
    "source": { "$ref": "#/$defs/source" },
    "review": { "$ref": "#/$defs/review" }
  },
  "$defs": {
    "uncertainty": { "type": ["object", "null"], "additionalProperties": false, "required": ["lower", "upper", "confidence", "method"], "properties": { "lower": { "type": "number" }, "upper": { "type": "number" }, "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }, "method": { "type": "string", "minLength": 1 } } },
    "source": { "type": "object", "additionalProperties": false, "required": ["source_registry_id", "document_title", "document_url", "locator", "version", "retrieved_at"], "properties": { "source_registry_id": { "type": "string", "minLength": 1 }, "document_title": { "type": "string", "minLength": 1 }, "document_url": { "type": "string", "pattern": "^https://" }, "locator": { "type": "string", "minLength": 1 }, "version": { "type": "string", "minLength": 1 }, "retrieved_at": { "type": "string", "format": "date" } } },
    "review": { "type": "object", "additionalProperties": false, "required": ["status", "extractor_id", "reviewer_id", "reviewed_at"], "properties": { "status": { "enum": ["not_reviewed", "in_review", "reviewed", "rejected", "superseded"] }, "extractor_id": { "type": "string", "minLength": 1 }, "reviewer_id": { "type": ["string", "null"] }, "reviewed_at": { "type": ["string", "null"], "format": "date-time" } } }
  }
}

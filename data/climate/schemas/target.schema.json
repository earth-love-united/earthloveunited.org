{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/target-2.0.0.json",
  "title": "Country climate target evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "target_id", "country_id", "target_type", "condition", "status", "target_year", "target_period", "reduction_pct", "target_value", "reference", "bau", "intensity", "trajectory", "peak_year", "statement", "net_zero", "scope", "comparability", "source_fact_ids", "review"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "target_id": { "type": "string", "pattern": "^target:[a-z0-9][a-z0-9._:-]+$" },
    "country_id": { "type": "string", "pattern": "^iso3166-1:[A-Z]{3}$" },
    "target_type": { "enum": ["base_year", "bau", "intensity", "fixed_level", "trajectory", "peaking", "sectoral", "qualitative", "net_zero"] },
    "condition": { "enum": ["unconditional", "conditional", "combined", "not_stated"] },
    "status": { "enum": ["active", "expired", "withdrawn", "superseded", "not_reviewed"] },
    "target_year": { "type": ["integer", "null"], "minimum": 1990, "maximum": 2200 },
    "target_period": { "type": ["string", "null"] },
    "reduction_pct": { "type": ["number", "null"], "minimum": -1000, "maximum": 100 },
    "target_value": { "$ref": "#/$defs/quantity" },
    "reference": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["year", "value", "fact_id"],
      "properties": {
        "year": { "type": ["integer", "null"], "minimum": 1850, "maximum": 2200 },
        "value": { "$ref": "#/$defs/quantity" },
        "fact_id": { "type": ["string", "null"], "pattern": "^fact:" }
      }
    },
    "bau": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["scenario_id", "vintage", "target_year_value", "source_fact_id"],
      "properties": {
        "scenario_id": { "type": ["string", "null"] },
        "vintage": { "type": ["string", "null"] },
        "target_year_value": { "$ref": "#/$defs/quantity" },
        "source_fact_id": { "type": ["string", "null"], "pattern": "^fact:" }
      }
    },
    "intensity": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["denominator_metric", "denominator_unit", "target_year_denominator_fact_id"],
      "properties": {
        "denominator_metric": { "type": ["string", "null"] },
        "denominator_unit": { "type": ["string", "null"] },
        "target_year_denominator_fact_id": { "type": ["string", "null"], "pattern": "^fact:" }
      }
    },
    "trajectory": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["pathway_fact_ids"],
      "properties": {
        "pathway_fact_ids": { "type": "array", "items": { "type": "string", "pattern": "^fact:" }, "uniqueItems": true }
      }
    },
    "peak_year": { "type": ["integer", "null"], "minimum": 1990, "maximum": 2200 },
    "statement": { "type": ["string", "null"] },
    "net_zero": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["residual_emissions", "removals_treatment", "offsets_treatment", "interim_target_ids"],
      "properties": {
        "residual_emissions": { "$ref": "#/$defs/quantity" },
        "removals_treatment": { "type": ["string", "null"] },
        "offsets_treatment": { "type": ["string", "null"] },
        "interim_target_ids": { "type": "array", "items": { "type": "string", "pattern": "^target:" }, "uniqueItems": true }
      }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accounting_frame", "gases", "sectors", "geography", "lulucf", "gwp_convention", "article6_treatment"],
      "properties": {
        "accounting_frame": { "enum": ["fossil_co2", "economy_wide_ghg", "sectoral", "other", "not_reported"] },
        "gases": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "sectors": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "geography": { "type": ["string", "null"] },
        "lulucf": { "enum": ["included", "excluded", "separate", "not_applicable", "not_reported"] },
        "gwp_convention": { "type": ["string", "null"] },
        "article6_treatment": { "type": ["string", "null"] }
      }
    },
    "comparability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reason_codes", "reviewed_against_fact_ids"],
      "properties": {
        "status": { "enum": ["comparable", "partially_comparable", "non_comparable", "qualitative_or_sectoral", "no_active_target_found", "not_assessed"] },
        "reason_codes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "reviewed_against_fact_ids": { "type": "array", "items": { "type": "string", "pattern": "^fact:" }, "uniqueItems": true }
      }
    },
    "source_fact_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^fact:" }, "uniqueItems": true },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "extractor_id", "reviewer_id", "reviewed_at"],
      "properties": {
        "status": { "enum": ["not_reviewed", "in_review", "reviewed", "rejected", "superseded"] },
        "extractor_id": { "type": ["string", "null"] },
        "reviewer_id": { "type": ["string", "null"] },
        "reviewed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  },
  "$defs": {
    "quantity": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["amount", "unit"],
      "properties": {
        "amount": { "type": "number" },
        "unit": { "type": "string", "minLength": 1 }
      }
    }
  }
}

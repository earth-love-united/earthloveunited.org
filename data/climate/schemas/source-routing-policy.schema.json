{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/source-routing-policy.schema.json",
  "title": "CT-16 versioned climate source-routing policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "policy_id",
    "routing_model_version",
    "created_at",
    "status",
    "purpose",
    "immutable_inputs",
    "governance_boundary",
    "route_rules",
    "routes",
    "reason_vocabulary",
    "prohibited_outputs",
    "calculation_hash"
  ],
  "properties": {
    "schema_version": { "const": "1.1.0" },
    "policy_id": { "const": "ct-16-source-routing-policy-v2-2026-07-15" },
    "routing_model_version": { "const": "2.1.0" },
    "created_at": { "type": "string", "pattern": "Z$" },
    "status": { "const": "blocked_pending_governance" },
    "purpose": { "type": "string", "minLength": 1 },
    "immutable_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_registry", "ct14_immutable_snapshot", "ct15_immutable_snapshot"],
      "properties": {
        "source_registry": { "$ref": "#/$defs/inputPin" },
        "ct14_immutable_snapshot": { "$ref": "#/$defs/inputPin" },
        "ct15_immutable_snapshot": { "$ref": "#/$defs/inputPin" }
      }
    },
    "governance_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_registry_modified",
        "rights_decisions_made",
        "ct40_decision_modified",
        "preexisting_factual_tier_state",
        "preexisting_factual_facts",
        "new_normalized_fact_uses_authorized",
        "scoring_authorized",
        "release_authority",
        "production_runtime_release"
      ],
      "properties": {
        "source_registry_modified": { "const": false },
        "rights_decisions_made": { "const": false },
        "ct40_decision_modified": { "const": false },
        "preexisting_factual_tier_state": { "const": "eligible_unchanged" },
        "preexisting_factual_facts": { "const": 2060 },
        "new_normalized_fact_uses_authorized": { "const": false },
        "scoring_authorized": { "const": false },
        "release_authority": { "const": false },
        "production_runtime_release": { "const": false }
      }
    },
    "route_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["official_inventory", "ndc_and_target"],
      "properties": {
        "official_inventory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_primary_source_roles",
            "corroboration_never_satisfies_primary",
            "btr_family_authorization_forbidden",
            "btr_component_identity_and_governance_required",
            "ter_primary_values_forbidden"
          ],
          "properties": {
            "required_primary_source_roles": {
              "const": ["primary_value_source", "conditional_primary_component"]
            },
            "corroboration_never_satisfies_primary": { "const": true },
            "btr_family_authorization_forbidden": { "const": true },
            "btr_component_identity_and_governance_required": { "const": true },
            "ter_primary_values_forbidden": { "const": true }
          }
        },
        "ndc_and_target": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required_source_registry_id",
            "official_inventory_use_forbidden",
            "active_or_reviewed_absence_status_required"
          ],
          "properties": {
            "required_source_registry_id": { "const": "unfccc-ndc-registry-continuous-2026-07-15" },
            "official_inventory_use_forbidden": { "const": true },
            "active_or_reviewed_absence_status_required": { "const": true }
          }
        }
      }
    },
    "routes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/route" }
    },
    "reason_vocabulary": {
      "type": "array",
      "minItems": 11,
      "maxItems": 11,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code"],
        "properties": { "code": { "type": "string", "minLength": 1 } }
      }
    },
    "prohibited_outputs": {
      "type": "array",
      "minItems": 7,
      "items": { "type": "string", "minLength": 1 }
    },
    "calculation_hash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "nullableSha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "nullableString": { "type": ["string", "null"] },
    "inputPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "explicitComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "permitted_types", "component_id", "document_checksum_sha256"],
      "properties": {
        "required": { "type": "boolean" },
        "permitted_types": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "component_id": { "$ref": "#/$defs/nullableString" },
        "document_checksum_sha256": { "$ref": "#/$defs/nullableSha256" }
      }
    },
    "currentGate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "state",
        "registry_domain_present",
        "registry_approval_state",
        "registry_redistribution_state",
        "registry_normalized_values_allowed",
        "governance_decision_id",
        "rights_decision_id",
        "independent_review_id",
        "normalized_fact_eligible",
        "scoring_eligible"
      ],
      "properties": {
        "state": { "enum": ["blocked_pending_rights_and_review", "blocked_role_domain_mismatch", "blocked_normalized_findings_pending"] },
        "registry_domain_present": { "type": "boolean" },
        "registry_approval_state": { "const": "pending" },
        "registry_redistribution_state": { "const": "metadata_only" },
        "registry_normalized_values_allowed": { "const": false },
        "governance_decision_id": { "type": "null" },
        "rights_decision_id": { "type": "null" },
        "independent_review_id": { "type": "null" },
        "normalized_fact_eligible": { "const": false },
        "scoring_eligible": { "const": false }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_id",
        "evidence_role",
        "source_registry_id",
        "source_role",
        "required_registry_domain",
        "structural_sufficiency",
        "family_level_inventory_authorization",
        "explicit_component",
        "prohibited_evidence_roles",
        "current_gate",
        "reason_codes"
      ],
      "properties": {
        "route_id": { "type": "string", "minLength": 1 },
        "evidence_role": { "enum": ["official_inventory", "official_inventory_corroboration", "active_ndc", "target_methodology"] },
        "source_registry_id": { "type": "string", "minLength": 1 },
        "source_role": { "enum": ["primary_value_source", "conditional_primary_component", "corroboration_only", "primary_document_source"] },
        "required_registry_domain": { "enum": ["official_inventory", "ndc_target"] },
        "structural_sufficiency": { "enum": ["primary_only_after_all_gates", "primary_only_for_explicit_governance_approved_component", "never_sufficient_as_primary_value_source"] },
        "family_level_inventory_authorization": { "const": false },
        "explicit_component": { "$ref": "#/$defs/explicitComponent" },
        "prohibited_evidence_roles": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "current_gate": { "$ref": "#/$defs/currentGate" },
        "reason_codes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  }
}

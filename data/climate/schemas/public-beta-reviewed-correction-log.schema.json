{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/public-beta-reviewed-correction-log-1.0.0.json",
  "title": "Reviewed Climate Public Beta correction log",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "schema_ref", "artifact_kind", "beta_release_id",
    "content_state", "review_input_pin", "policy", "entries", "assessed_production_authority",
    "calculation_hash"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "schema_ref": { "const": "data/climate/schemas/public-beta-reviewed-correction-log.schema.json" },
    "artifact_kind": { "const": "public_beta_correction_log" },
    "beta_release_id": { "$ref": "#/$defs/releaseId" },
    "content_state": { "const": "reviewed_beta_release" },
    "review_input_pin": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "pattern": "^private-review/climate-public-beta/(?!.*\\.\\.)[a-z0-9][a-z0-9.-]{1,62}[a-z0-9]/prior-corrections\\.review-input\\.json$"
        },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "current_release_statement"],
      "properties": {
        "scope": { "type": "string", "minLength": 1 },
        "current_release_statement": { "type": "string", "minLength": 1 }
      }
    },
    "entries": {
      "type": "array",
      "maxItems": 100,
      "items": { "$ref": "#/$defs/correctionEntry" }
    },
    "assessed_production_authority": { "const": false },
    "calculation_hash": { "$ref": "#/$defs/sha256" }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "releaseId": { "type": "string", "pattern": "^(?!.*\\.\\.)[a-z0-9][a-z0-9.-]{1,62}[a-z0-9]$" },
    "artifactPin": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 3 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "correctionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correction_id", "superseded_release_id", "corrected_in_release_id",
        "recorded_at", "category", "description", "affected_artifacts",
        "decision_reference"
      ],
      "properties": {
        "correction_id": {
          "type": "string",
          "pattern": "^corr-[a-f0-9]{16,64}$"
        },
        "superseded_release_id": { "$ref": "#/$defs/releaseId" },
        "corrected_in_release_id": { "$ref": "#/$defs/releaseId" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "category": { "enum": ["source_identity", "source_locator", "transformation", "value", "limitation", "display_wording"] },
        "description": { "type": "string", "minLength": 20 },
        "affected_artifacts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/artifactPin" }
        },
        "decision_reference": {
          "type": "string",
          "pattern": "^elu-correction-decision:[a-f0-9]{16,64}$"
        }
      }
    },
    "priorCorrectionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version", "artifact_kind", "beta_release_id",
        "private_review_only", "publication_authority",
        "assessed_production_authority", "entries"
      ],
      "properties": {
        "schema_version": { "const": "1.0.0" },
        "artifact_kind": { "const": "public_beta_prior_correction_review_input" },
        "beta_release_id": { "$ref": "#/$defs/releaseId" },
        "private_review_only": { "const": true },
        "publication_authority": { "const": false },
        "assessed_production_authority": { "const": false },
        "entries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/correctionEntry" }
        }
      }
    }
  }
}

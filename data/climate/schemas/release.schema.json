{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate/release-2.0.0.json",
  "title": "Country climate data release manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "data_release_id", "methodology_version", "created_at", "country_registry", "source_release_ids", "artifacts", "coverage", "review", "previous_release_id", "change_summary"],
  "properties": {
    "schema_version": { "const": "2.0.0" },
    "data_release_id": { "type": "string", "pattern": "^climate-[0-9]{4}-[0-9]{2}-[0-9]{2}(?:\\.[0-9]+)?$" },
    "methodology_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "created_at": { "type": "string", "format": "date-time" },
    "country_registry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data_release_id", "checksum_sha256", "entity_count"],
      "properties": {
        "data_release_id": { "type": "string", "minLength": 1 },
        "checksum_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "entity_count": { "type": "integer", "minimum": 1 }
      }
    },
    "source_release_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "media_type", "checksum_sha256", "record_count"],
        "properties": {
          "path": { "type": "string", "pattern": "^data/climate/" },
          "media_type": { "const": "application/json" },
          "checksum_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "record_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["registry_entities", "profiles", "release_eligible", "not_assessed"],
      "properties": {
        "registry_entities": { "type": "integer", "minimum": 1 },
        "profiles": { "type": "integer", "minimum": 0 },
        "release_eligible": { "type": "integer", "minimum": 0 },
        "not_assessed": { "type": "integer", "minimum": 0 }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "builder_id", "reviewer_ids", "reviewed_at"],
      "properties": {
        "status": { "enum": ["not_reviewed", "in_review", "reviewed", "rejected", "superseded"] },
        "builder_id": { "type": "string", "minLength": 1 },
        "reviewer_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "reviewed_at": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "previous_release_id": { "type": ["string", "null"] },
    "change_summary": { "type": "string", "minLength": 1 }
  }
}

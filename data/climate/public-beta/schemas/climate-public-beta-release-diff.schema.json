{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate-public-beta/release-diff-1.0.0.json",
  "title": "Exact Climate Public Beta public-surface release diff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "diff_id",
    "beta_release_id",
    "previous_beta_release_id",
    "initial_release",
    "baseline_kind",
    "comparison_surface",
    "assessed_production_authority",
    "changes",
    "summary",
    "calculation_hash"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "diff_id": { "type": "string", "pattern": "^elu-climate-public-beta-public-surface-diff-(?!.*\\.\\.)[a-z0-9][a-z0-9.-]{1,62}[a-z0-9]$" },
    "beta_release_id": { "$ref": "#/$defs/releaseId" },
    "previous_beta_release_id": {
      "oneOf": [
        { "type": "null" },
        { "$ref": "#/$defs/releaseId" }
      ]
    },
    "initial_release": { "type": "boolean" },
    "baseline_kind": { "enum": ["no_prior_beta", "prior_immutable_beta_release"] },
    "comparison_surface": { "const": "exact_dedicated_beta_public_surface" },
    "assessed_production_authority": { "const": false },
    "changes": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "$ref": "#/$defs/change" } },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["added", "modified", "removed", "total"],
      "properties": {
        "added": { "type": "integer", "minimum": 0 },
        "modified": { "type": "integer", "minimum": 0 },
        "removed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 1 }
      }
    },
    "calculation_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  },
  "$defs": {
    "releaseId": { "type": "string", "pattern": "^(?!.*\\.\\.)[a-z0-9][a-z0-9.-]{1,62}[a-z0-9]$" },
    "nullableHash": { "type": ["string", "null"] },
    "change": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "change", "before_sha256", "after_sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^[A-Za-z0-9._/-]+$" },
        "change": { "enum": ["added", "modified", "removed"] },
        "before_sha256": { "$ref": "#/$defs/nullableHash" },
        "after_sha256": { "$ref": "#/$defs/nullableHash" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://earthloveunited.org/schemas/climate-public-beta-ui-accessibility-results.schema.json",
  "title": "Climate Public Beta UI, accessibility, and comprehension review results",
  "description": "Release-specific, human-supplied observations bound to exact frozen governance contracts. A passing record grants no human, publication, legal, or assessed-production authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "results_id",
    "status",
    "repository",
    "product_tier",
    "beta_release_id",
    "publication_level",
    "reviewed_commit_sha",
    "review_protocol_id",
    "review_protocol_sha256",
    "feedback_privacy_contract_id",
    "feedback_privacy_contract_sha256",
    "started_at",
    "completed_at",
    "reviewer_identity",
    "session_summaries",
    "matrix_check_results",
    "comprehension_sessions",
    "findings",
    "aggregate",
    "result",
    "assessed_production_authority",
    "calculation_hash"
  ],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "results_id": {
      "type": "string",
      "pattern": "^elu-climate-public-beta-[a-z0-9][a-z0-9.-]*[a-z0-9]-ui-accessibility-v1$"
    },
    "status": { "const": "completed" },
    "repository": { "const": "earth-love-united/earthloveunited.org" },
    "product_tier": { "const": "climate_public_beta" },
    "beta_release_id": { "$ref": "#/$defs/releaseId" },
    "publication_level": { "enum": ["invited_beta", "public_beta"] },
    "reviewed_commit_sha": { "$ref": "#/$defs/commit" },
    "review_protocol_id": { "const": "elu-climate-public-beta-review-protocol-v1" },
    "review_protocol_sha256": { "$ref": "#/$defs/hash" },
    "feedback_privacy_contract_id": { "const": "elu-climate-public-beta-feedback-privacy-v1" },
    "feedback_privacy_contract_sha256": { "$ref": "#/$defs/hash" },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" },
    "reviewer_identity": { "$ref": "#/$defs/reference" },
    "session_summaries": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/sessionSummary" }
    },
    "matrix_check_results": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/matrixCheckResult" }
    },
    "comprehension_sessions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/comprehensionSession" }
    },
    "findings": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/finding" }
    },
    "aggregate": { "$ref": "#/$defs/aggregate" },
    "result": { "const": "review_complete_no_go_clear" },
    "assessed_production_authority": { "const": false },
    "calculation_hash": { "$ref": "#/$defs/hash" }
  },
  "$defs": {
    "releaseId": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)[a-z0-9][a-z0-9.-]{1,62}[a-z0-9]$"
    },
    "hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "reference": { "type": "string", "minLength": 5, "maxLength": 512 },
    "sessionSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "reviewer_reference",
        "started_at",
        "completed_at",
        "matrix_ids",
        "accessibility_session",
        "evidence_reference"
      ],
      "properties": {
        "session_id": { "type": "string", "pattern": "^session-[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "reviewer_reference": { "type": "string", "pattern": "^reviewer:[0-9a-f]{16,64}$" },
        "started_at": { "type": "string", "format": "date-time" },
        "completed_at": { "type": "string", "format": "date-time" },
        "matrix_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^matrix-[a-z0-9][a-z0-9-]*[a-z0-9]$" }
        },
        "accessibility_session": { "type": "boolean" },
        "evidence_reference": { "$ref": "#/$defs/reference" }
      }
    },
    "matrixCheckResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "matrix_id",
        "check_id",
        "outcome",
        "finding_ids",
        "observed_at",
        "evidence_reference"
      ],
      "properties": {
        "case_id": { "type": "string", "minLength": 12, "maxLength": 256 },
        "matrix_id": { "type": "string", "pattern": "^matrix-[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "check_id": { "type": "string", "pattern": "^check-[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "outcome": { "enum": ["pass", "finding_recorded"] },
        "finding_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^finding-[0-9a-f]{16,64}$" }
        },
        "observed_at": { "type": "string", "format": "date-time" },
        "evidence_reference": { "$ref": "#/$defs/reference" }
      }
    },
    "comprehensionSession": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "prompt_results", "session_passed"],
      "properties": {
        "session_id": { "type": "string", "pattern": "^session-[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "prompt_results": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/promptResult" }
        },
        "session_passed": { "type": "boolean" }
      }
    },
    "promptResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_id",
        "identified_concepts",
        "critical_misunderstanding_detected",
        "passed"
      ],
      "properties": {
        "prompt_id": { "type": "string", "pattern": "^prompt-[a-z0-9][a-z0-9-]*[a-z0-9]$" },
        "identified_concepts": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^concept-[a-z0-9][a-z0-9-]*[a-z0-9]$" }
        },
        "critical_misunderstanding_detected": { "type": "boolean" },
        "passed": { "type": "boolean" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_id",
        "severity",
        "status",
        "summary",
        "evidence_reference",
        "reported_at",
        "resolved_at"
      ],
      "properties": {
        "finding_id": { "type": "string", "pattern": "^finding-[0-9a-f]{16,64}$" },
        "severity": { "enum": ["critical", "high", "medium", "low"] },
        "status": { "enum": ["open", "resolved", "accepted_beta_limitation"] },
        "summary": { "type": "string", "minLength": 20, "maxLength": 1000 },
        "evidence_reference": { "$ref": "#/$defs/reference" },
        "reported_at": { "type": "string", "format": "date-time" },
        "resolved_at": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "format": "date-time" }
          ]
        }
      }
    },
    "aggregate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unique_reviewer_count",
        "completed_session_count",
        "accessibility_session_count",
        "matrix_case_count",
        "matrix_case_pass_count",
        "open_no_go_finding_count",
        "comprehension_session_count",
        "comprehension_session_pass_count",
        "comprehension_pass_rate_basis_points",
        "critical_misunderstanding_count",
        "invited_duration_observed_seconds",
        "all_matrix_and_check_coverage_complete",
        "minimums_satisfied",
        "no_go_clear"
      ],
      "properties": {
        "unique_reviewer_count": { "type": "integer", "minimum": 0 },
        "completed_session_count": { "type": "integer", "minimum": 0 },
        "accessibility_session_count": { "type": "integer", "minimum": 0 },
        "matrix_case_count": { "type": "integer", "minimum": 0 },
        "matrix_case_pass_count": { "type": "integer", "minimum": 0 },
        "open_no_go_finding_count": { "type": "integer", "minimum": 0 },
        "comprehension_session_count": { "type": "integer", "minimum": 0 },
        "comprehension_session_pass_count": { "type": "integer", "minimum": 0 },
        "comprehension_pass_rate_basis_points": { "type": "integer", "minimum": 0, "maximum": 10000 },
        "critical_misunderstanding_count": { "type": "integer", "minimum": 0 },
        "invited_duration_observed_seconds": { "type": "integer", "minimum": 0 },
        "all_matrix_and_check_coverage_complete": { "const": true },
        "minimums_satisfied": { "const": true },
        "no_go_clear": { "const": true }
      }
    }
  }
}
